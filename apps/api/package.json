{
  "name": "@starville/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node ../../scripts/with-env.mjs --profile api tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf dist coverage .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cookie": "11.1.1",
    "@fastify/cors": "^11.3.0",
    "@fastify/multipart": "10.1.0",
    "@starville/admin-auth": "workspace:*",
    "@starville/asset-management": "workspace:*",
    "@starville/avatar": "workspace:*",
    "@starville/config": "workspace:*",
    "@starville/cooperative-activities": "workspace:*",
    "@starville/cozy-gameplay": "workspace:*",
    "@starville/cosmetics": "workspace:*",
    "@starville/economy": "workspace:*",
    "@starville/economy-simulation": "workspace:*",
    "@starville/game-core": "workspace:*",
    "@starville/game-content": "workspace:*",
    "@starville/housing": "workspace:*",
    "@starville/housing-simulation": "workspace:*",
    "@starville/logger": "workspace:*",
    "@starville/live-operations": "workspace:*",
    "@starville/player-operations": "workspace:*",
    "@starville/platform-configuration": "workspace:*",
    "@starville/player-experience": "workspace:*",
    "@starville/progression": "workspace:*",
    "@starville/progression-simulation": "workspace:*",
    "@starville/realtime": "workspace:*",
    "@starville/solana": "workspace:*",
    "@starville/shared-types": "workspace:*",
    "@starville/supabase": "workspace:*",
    "@starville/wallet-access": "workspace:*",
    "@supabase/supabase-js": "^2.110.1",
    "fastify": "^5.10.0",
    "sharp": "0.34.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@starville/eslint-config": "workspace:*",
    "@starville/typescript-config": "workspace:*",
    "@types/node": "^22.20.1",
    "@solana/web3.js": "1.98.4",
    "eslint": "^9.39.4",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "tweetnacl": "1.0.3",
    "vitest": "^4.1.10"
  }
}
