    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@starville/eslint-config": "workspace:*",
    "@starville/testing": "workspace:*",
    "@starville/typescript-config": "workspace:*",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
