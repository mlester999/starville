{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.example", "tsconfig.json"],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_APP_ENV",
    "NEXT_PUBLIC_LANDING_URL",
    "NEXT_PUBLIC_GAME_URL",
    "NEXT_PUBLIC_ADMIN_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_REALTIME_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "LANDING_PORT",
    "GAME_CLIENT_PORT",
    "ADMIN_PORT",
    "API_HOST",
    "API_PORT",
    "REALTIME_HOST",
    "REALTIME_PORT",
    "WORKER_HOST",
    "WORKER_HEALTH_PORT",
    "CORS_ALLOWED_ORIGINS",
    "REALTIME_ALLOWED_ORIGINS",
    "REALTIME_MAX_CONNECTIONS",
    "WORKER_CONCURRENCY",
    "WORKER_MAX_ATTEMPTS",
    "WORKER_RETRY_BASE_DELAY_MS",
    "LOG_LEVEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    },
    "@starville/landing#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@starville/admin-portal#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@starville/game-client#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "@starville/api#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "@starville/realtime-server#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "@starville/worker#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
