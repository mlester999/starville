{
  "name": "starville",
  "version": "0.1.0",
  "private": true,
  "description": "Production monorepo for the Starville cozy multiplayer game platform.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "node scripts/with-env.mjs turbo run dev",
    "dev:landing": "node scripts/with-env.mjs turbo run dev --filter=@starville/landing",
    "dev:game": "node scripts/with-env.mjs turbo run dev --filter=@starville/game-client",
    "dev:admin": "node scripts/with-env.mjs turbo run dev --filter=@starville/admin-portal",
    "dev:api": "node scripts/with-env.mjs turbo run dev --filter=@starville/api",
    "dev:realtime": "node scripts/with-env.mjs turbo run dev --filter=@starville/realtime-server",
    "dev:worker": "node scripts/with-env.mjs turbo run dev --filter=@starville/worker",
    "build": "node scripts/with-env.mjs --set NODE_ENV=production turbo run build",
    "lint": "turbo run lint && pnpm lint:root",
    "lint:root": "eslint scripts --max-warnings=0",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write --cache .",
    "format:check": "prettier --check --cache .",
    "clean": "turbo run clean && rimraf .turbo coverage",
    "env:check": "node scripts/with-env.mjs tsx scripts/validate-environment.ts",
    "supabase:start": "pnpm dlx supabase@2.109.1 --workdir infrastructure start",
    "supabase:status": "pnpm dlx supabase@2.109.1 --workdir infrastructure status",
    "supabase:stop": "pnpm dlx supabase@2.109.1 --workdir infrastructure stop"
  },
  "devDependencies": {
    "@starville/config": "workspace:*",
    "@starville/eslint-config": "workspace:*",
    "@starville/shared-validation": "workspace:*",
    "@types/node": "22.20.1",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "supabase": "^2.109.1",
    "tsx": "4.23.0",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
