{
  "name": "starville",
  "version": "0.1.0",
  "private": true,
  "description": "Production monorepo for the Starville cozy multiplayer game platform.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:landing": "turbo run dev --filter=@starville/landing",
    "dev:game": "turbo run dev --filter=@starville/game-client",
    "dev:admin": "turbo run dev --filter=@starville/admin-portal",
    "dev:api": "turbo run dev --filter=@starville/api",
    "dev:realtime": "turbo run dev --filter=@starville/realtime-server",
    "dev:worker": "turbo run dev --filter=@starville/worker",
    "build": "pnpm assets:validate && node scripts/with-env.mjs --set NODE_ENV=production turbo run build",
    "lint": "turbo run lint && pnpm lint:root",
    "lint:root": "eslint scripts --max-warnings=0",
    "typecheck": "turbo run typecheck && pnpm typecheck:root",
    "typecheck:root": "tsc -p scripts/tsconfig.json",
    "test": "turbo run test && pnpm test:root",
    "test:root": "vitest run scripts",
    "format": "prettier --write --cache .",
    "format:check": "prettier --check --cache .",
    "clean": "turbo run clean && rimraf .turbo coverage",
    "env:check": "node scripts/with-env.mjs tsx scripts/validate-environment.ts",
    "release:validate": "node scripts/with-env.mjs tsx scripts/phase13c-release-readiness.ts",
    "production:audit": "tsx scripts/phase13d-production-readiness.ts audit",
    "production:verify-target": "node scripts/with-env.mjs tsx scripts/phase13d-production-readiness.ts verify-target",
    "production:verify-token": "node scripts/with-env.mjs tsx scripts/phase13d-production-readiness.ts verify-token",
    "production:migrations:compare": "tsx scripts/phase13d-production-readiness.ts compare-migrations",
    "release:check": "pnpm release:validate && pnpm env:check && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm security:scan",
    "env:phase3:prepare": "tsx scripts/prepare-phase3-environment.ts",
    "env:phase3:close-maintenance": "tsx scripts/prepare-phase3-environment.ts --close-maintenance",
    "security:scan": "tsx scripts/security-scan.ts",
    "realtime:load:test": "pnpm --filter @starville/realtime-server load:test",
    "economy:load:test": "tsx scripts/economy-load-test.ts",
    "token-claim:load:test": "tsx scripts/token-claim-load-test.ts",
    "avatar:renderer:load:test": "tsx scripts/avatar-renderer-load-test.ts",
    "phase12f:a1:performance": "tsx scripts/phase12f-a1-performance.ts",
    "assets:generate": "pnpm --filter @starville/asset-pipeline generate && pnpm --filter @starville/asset-pipeline generate:phase12d && pnpm --filter @starville/asset-pipeline generate:phase12f",
    "assets:generate:phase12d": "pnpm --filter @starville/asset-pipeline generate:phase12d",
    "assets:generate:phase12f": "pnpm --filter @starville/asset-pipeline generate:phase12f",
    "assets:validate": "pnpm --filter @starville/asset-pipeline validate && pnpm --filter @starville/asset-pipeline validate:phase12d && pnpm --filter @starville/asset-pipeline validate:phase12f",
    "assets:validate:phase12d": "pnpm --filter @starville/asset-pipeline validate:phase12d",
    "assets:validate:phase12f": "pnpm --filter @starville/asset-pipeline validate:phase12f",
    "assets:manifest": "pnpm --filter @starville/asset-pipeline manifest && pnpm --filter @starville/asset-pipeline exec tsx src/cli.ts manifest-phase12d && pnpm --filter @starville/asset-pipeline exec tsx src/cli.ts manifest-phase12f",
    "assets:thumbnails": "pnpm --filter @starville/asset-pipeline thumbnails && pnpm --filter @starville/asset-pipeline exec tsx src/cli.ts thumbnails-phase12d && pnpm --filter @starville/asset-pipeline exec tsx src/cli.ts thumbnails-phase12f",
    "assets:coverage": "pnpm --filter @starville/asset-pipeline coverage && pnpm --filter @starville/asset-pipeline exec tsx src/cli.ts coverage-phase12d && pnpm --filter @starville/asset-pipeline exec tsx src/cli.ts coverage-phase12f",
    "assets:check": "pnpm --filter @starville/asset-pipeline check && pnpm --filter @starville/asset-pipeline check:phase12d && pnpm --filter @starville/asset-pipeline check:phase12f",
    "audio:validate": "tsx scripts/validate-release-candidate-audio.ts",
    "wallet:test:live": "node scripts/with-env.mjs tsx scripts/phase3-live-wallet-smoke.ts",
    "db:verify-target": "node scripts/with-env.mjs tsx scripts/supabase/remote-command.ts verify",
    "db:migrations:list": "node scripts/with-env.mjs tsx scripts/supabase/remote-command.ts list",
    "db:migrations:dry-run": "node scripts/with-env.mjs tsx scripts/supabase/remote-command.ts dry-run",
    "phase13e:migrations:review": "tsx scripts/supabase/phase13e-pending-migration-review.ts",
    "db:migrations:push": "node scripts/with-env.mjs tsx scripts/supabase/remote-command.ts push",
    "db:lint:hosted": "node scripts/with-env.mjs tsx scripts/supabase/remote-command.ts lint",
    "db:test:hosted": "node scripts/with-env.mjs tsx scripts/supabase/hosted-database-tests.ts",
    "realtime:settings:verify": "node scripts/with-env.mjs tsx scripts/supabase/verify-realtime-settings.ts",
    "phase13e:realtime:hosted": "node scripts/with-env.mjs tsx scripts/supabase/phase13e-hosted-realtime-validation.ts",
    "phase13e:cleanup:hosted": "node scripts/with-env.mjs tsx scripts/supabase/phase13e-hosted-cleanup-validation.ts",
    "db:test:local:world": "tsx scripts/supabase/local-world-postgres-tests.ts",
    "rls:test:hosted": "node scripts/with-env.mjs tsx scripts/supabase/hosted-rls-tests.ts",
    "admin:bootstrap": "node scripts/with-env.mjs tsx scripts/supabase/bootstrap-admin.ts",
    "supabase:start": "pnpm dlx supabase@2.109.1 --workdir infrastructure start",
    "supabase:status": "pnpm dlx supabase@2.109.1 --workdir infrastructure status",
    "supabase:stop": "pnpm dlx supabase@2.109.1 --workdir infrastructure stop"
  },
  "devDependencies": {
    "@starville/admin-auth": "workspace:*",
    "@starville/avatar": "workspace:*",
    "@starville/config": "workspace:*",
    "@starville/cosmetics": "workspace:*",
    "@starville/eslint-config": "workspace:*",
    "@starville/economy-simulation": "workspace:*",
    "@starville/progression": "workspace:*",
    "@starville/progression-simulation": "workspace:*",
    "@starville/realtime": "workspace:*",
    "@starville/shared-validation": "workspace:*",
    "@starville/solana": "workspace:*",
    "@starville/supabase": "workspace:*",
    "@starville/token-claim-architecture": "workspace:*",
    "@starville/wallet-access": "workspace:*",
    "@types/node": "22.20.1",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "prettier": "3.9.5",
    "postgres": "^3.4.8",
    "rimraf": "6.1.3",
    "supabase": "^2.109.1",
    "tsx": "4.23.0",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "zod": "4.1.12"
  }
}
