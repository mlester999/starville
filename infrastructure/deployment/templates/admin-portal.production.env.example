# Starville Admin Portal production template. There is no public administrator registration.
NODE_ENV=production
STARVILLE_DEPLOYMENT_TARGET=starville-prod
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_ADMIN_URL=https://OWNER_REQUIRED_ADMIN_DOMAIN.invalid
NEXT_PUBLIC_API_URL=https://OWNER_REQUIRED_API_DOMAIN.invalid
NEXT_PUBLIC_GAME_URL=https://OWNER_REQUIRED_GAME_DOMAIN.invalid
NEXT_PUBLIC_SUPABASE_URL=https://OWNER_REQUIRED_PRODUCTION_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=OWNER_REQUIRED_PROVIDER_PUBLIC_ANON_KEY
ADMIN_PORT=3002
ADMIN_RECOVERY_COOKIE_SECRET=OWNER_REQUIRED_PROVIDER_SECRET_REFERENCE
SUPABASE_REMOTE_WRITES_APPROVED=false
ADMIN_BOOTSTRAP_ENABLED=false
RUN_HOSTED_SUPABASE_TESTS=false
SOURCE_MAPS=false
PUBLIC_SOURCE_MAPS=false
