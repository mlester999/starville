NEXT_PUBLIC_APP_ENV=production
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=4000
API_TRUSTED_PROXY_CIDRS=OWNER_REQUIRED_PROVIDER_PROXY_CIDRS
