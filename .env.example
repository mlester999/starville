# ================================================================
# STARVILLE PHASE 3 ENVIRONMENT TEMPLATE
# Copy to .env.local for local overrides. Never commit real values.
# ================================================================

# Required now by all Node services (server-only)
NODE_ENV=development
LOG_LEVEL=debug

# Browser-safe and required now. Values with NEXT_PUBLIC_ are bundled publicly.
# Production deployments must use HTTPS/WSS; cleartext is accepted only for local loopback development.
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_LANDING_URL=http://localhost:3000
NEXT_PUBLIC_GAME_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_REALTIME_URL=ws://localhost:4001
NEXT_PUBLIC_REOWN_PROJECT_ID=your-reown-project-id
# Optional official community destinations. Leave blank until owner-approved URLs exist.
NEXT_PUBLIC_STARVILLE_X_URL=
NEXT_PUBLIC_STARVILLE_DISCORD_URL=

# Browser-safe Supabase configuration. Replace locally; never use service-role here.
NEXT_PUBLIC_SUPABASE_URL=https://exampleprojectref001.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase configuration. Privileged helpers validate these only when used.
SUPABASE_SERVICE_ROLE_KEY=server-only-placeholder
SUPABASE_DATABASE_URL=postgresql://placeholder

# Hosted Starville Dev safety gates (server-only; required in Phase 2).
# Keep every approval false until intentionally performing that exact operation.
SUPABASE_ENVIRONMENT=development
SUPABASE_PROJECT_REF=exampleprojectref001
SUPABASE_REMOTE_WRITES_APPROVED=false
RUN_HOSTED_SUPABASE_TESTS=false

# Administrator authorization controls (server-only; required in Phase 2).
# Trusted administrator sessions must be between 1 and 60 minutes.
ADMIN_SESSION_TTL_MINUTES=60
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_REQUIRE_MFA_BY_DEFAULT=false
ADMIN_RECOVERY_COOKIE_SECRET=replace-with-at-least-32-random-characters

# Application ports and bind addresses (server-only; required now)
LANDING_PORT=3000
GAME_CLIENT_PORT=3001
ADMIN_PORT=3002
API_HOST=127.0.0.1
API_PORT=4000
# Empty by default. In deployment, list only the exact reverse-proxy IPs/CIDRs the API trusts.
API_TRUSTED_PROXY_CIDRS=
REALTIME_HOST=127.0.0.1
REALTIME_PORT=4001
WORKER_HOST=127.0.0.1
WORKER_HEALTH_PORT=4002

# Cross-origin and service safety controls (server-only; required now)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
REALTIME_ALLOWED_ORIGINS=http://localhost:3001
REALTIME_MAX_CONNECTIONS=100
WORKER_CONCURRENCY=1
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BASE_DELAY_MS=1000

# Phase 3 Solana token-access configuration.
# Network, symbol, mint, and display requirement are non-secret identifiers.
# Supported Phase 3 values: devnet or mainnet-beta. Keep the public Devnet endpoint as the safe example.
SOLANA_NETWORK=devnet
GAME_TOKEN_SYMBOL=STAR
GAME_TOKEN_GATE_AMOUNT=1000
GAME_TOKEN_MINT_ADDRESS=11111111111111111111111111111111
TOKEN_GATE_ENABLED=true

# Server-only RPC and wallet-authentication configuration. Provider keys embedded in
# SOLANA_RPC_URL are secrets even though the example uses the public devnet endpoint.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed
SOLANA_RPC_TIMEOUT_MS=5000
SOLANA_RPC_MAX_ATTEMPTS=2
WALLET_CHALLENGE_TTL_SECONDS=300
TOKEN_ACCESS_SESSION_TTL_SECONDS=900
TOKEN_ACCESS_RECHECK_SECONDS=300
TOKEN_ACCESS_COOKIE_SECRET=replace-with-an-independent-random-secret-at-least-32-characters

# Server-only abuse controls. Durable challenge, verification, and recheck limits are
# also enforced through trusted database functions.
TOKEN_ACCESS_CHALLENGE_RATE_LIMIT=5
TOKEN_ACCESS_VERIFY_RATE_LIMIT=10
TOKEN_ACCESS_RECHECK_RATE_LIMIT=4
TOKEN_GATE_ADMIN_VALIDATE_RATE_LIMIT=5
